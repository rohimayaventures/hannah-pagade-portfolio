# Canonical site URL for Open Graph / metadata (optional; Vercel VERCEL_URL is used as fallback)
NEXT_PUBLIC_SITE_URL=

# Where contact form submissions are delivered
CONTACT_TO_EMAIL=

# Option A — Resend (From must be on a domain verified in Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Hannah Pagade <hello@yourdomain.com>

# Option B — Gmail (if set with app password, used before Resend)
# https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=
