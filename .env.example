# ──────────────────────────────────────────────
# Portfolio Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local — it is gitignored
# ──────────────────────────────────────────────

# Canonical site URL for Open Graph metadata (optional; Vercel VERCEL_URL is used as fallback)
NEXT_PUBLIC_SITE_URL=

# ── Contact Form (/api/contact) ─────────────
# Where contact form submissions are delivered
CONTACT_TO_EMAIL=

# Option A — Gmail (used first if both Gmail and Resend are configured)
# Create an App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Option B — Resend (From address must be on a domain verified in Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Hannah Kraulik Pagade <hello@yourdomain.com>

# ── Kai Concierge (/api/concierge) ──────────
# Anthropic API key for Claude-powered portfolio assistant
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Lead Notifications (/api/notify) ────────
# Slack incoming webhook for lead alerts
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
